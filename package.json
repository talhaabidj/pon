{
  "name": "catchapon",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Catchapon — A cozy first-person Japanese gacha department store game",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,html,md}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{json,html,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.50.0",
    "@types/three": "^0.175.0",
    "eslint": "^9.18.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.4.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.3.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "howler": "^2.2.4",
    "three": "^0.175.0"
  }
}
